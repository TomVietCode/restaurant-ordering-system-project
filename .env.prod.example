# --- DATABASE CONFIG ---
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=restaurant_ordering
DB_USER=postgres
# IMPORTANT: Change this to a secure password on production VPS
DB_PASS=your_secure_production_db_password
# Set to true if connecting to a cloud DB that requires SSL (e.g. Neon, AWS RDS, Supabase)
DB_SSL=false

# --- BACKEND SECURITY CONFIG ---
# Generate secure keys using: openssl rand -hex 32
JWT_ACCESS_SECRET=your_jwt_access_secret_hex
JWT_REFRESH_SECRET=your_jwt_refresh_secret_hex
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- CORS CONFIG (Multiple origins allowed, comma-separated, NO SPACES) ---
# Format: origin1,origin2,origin3
# Example: http://your-vps-ip:3001,https://admin.yourdomain.com
CORS_ORIGIN=http://localhost:3001,http://your-vps-ip:3001,https://admin.yourdomain.com

# --- STORAGE CONFIG (S3 / DigitalOcean Spaces) ---
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=sgp1

# --- VNPAY CONFIG ---
VNPAY_TMN_CODE=your_tmn_code
VNPAY_SECURE_SECRET=your_secure_secret
VNPAY_RETURN_URL=https://api.yourdomain.com/api/payments/callback

# --- FRONTEND AUTH CONFIG ---
# Used by NextAuth.js on the frontend container. Generate using: openssl rand -hex 32
AUTH_SECRET=your_nextauth_session_secret_hex
